# Supabase — crie um projeto em https://supabase.com e copie estes valores em Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — crie uma chave em https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Opcional — modelo usado para gerar treino e dieta (padrão: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
