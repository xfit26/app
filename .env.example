# URL pública do site em produção (usada em robots.txt e sitemap.xml)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — crie um projeto em https://supabase.com e copie estes valores em Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project Settings > API > service_role — NUNCA exponha no client. Usada só
# pelas rotas de servidor que gravam assinaturas (webhook e /api/assinatura).
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — crie uma chave em https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Opcional — modelo usado para gerar treino, dieta e o chat (padrão: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Pagar.me — https://dashboard.pagar.me (use chaves de teste "sk_test_"/"pk_test_" antes de produção)
PAGARME_SECRET_KEY=
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=
# Credenciais que você mesmo escolhe e configura na URL do webhook cadastrada
# no painel da Pagar.me: https://usuario:senha@seu-dominio.com/api/webhooks/pagarme
PAGARME_WEBHOOK_USER=
PAGARME_WEBHOOK_PASSWORD=
# Opcional — preço em centavos dos planos (padrão: 2990 = R$29,90 / 29900 = R$299,00)
PAGARME_PLAN_MENSAL_PRICE_CENTS=2990
PAGARME_PLAN_ANUAL_PRICE_CENTS=29900
